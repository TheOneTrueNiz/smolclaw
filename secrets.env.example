# SmolClaw Secrets — DO NOT COMMIT THIS FILE
# Copy to ~/.config/smolclaw/brave.key with just the key value, OR
# export as environment variable: export BRAVE_API_KEY=your_key_here
#
# Get a Brave Search API key at: https://brave.com/search/api/
#
# Setup:
#   echo "BSA-your-key-here" > ~/.config/smolclaw/brave.key
#   chmod 600 ~/.config/smolclaw/brave.key
